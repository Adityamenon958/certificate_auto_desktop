# Copy this file to .env next to CertificateAuto.exe and fill in real values.
# Do not share .env with passwords in email or public links.

# Email (required for Generate & Send)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SENDER_EMAIL=your-email@gmail.com

# Optional
OUTPUT_DIR=certificates
UNSUBSCRIBE_LINK=https://leveluponline.shop/
